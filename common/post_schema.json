{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedSocialPost",
  "type": "object",
  "properties": {
    "post_id": { "type": "string" },
    "timestamp": { "type": ["string", "null"] },
    "text": { "type": "string" },
    "author": { "type": ["string", "null"] },
    "source": { "type": "string" },
    "is_repost": { "type": "boolean" }
  },
  "required": ["post_id", "text", "source", "is_repost"]
}